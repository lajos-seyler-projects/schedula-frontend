{
  "name": "vite-ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "cypress run --component --browser chrome",
    "testE2E": "cypress run --e2e --browser chrome",
    "test:open": "cypress open --component --browser chrome",
    "testE2E:open": "cypress open --e2e --browser chrome",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.98.0",
    "@tanstack/react-query-devtools": "^5.98.0",
    "@ui5/webcomponents": "2.21.0",
    "@ui5/webcomponents-base": "2.21.0",
    "@ui5/webcomponents-fiori": "2.21.0",
    "@ui5/webcomponents-icons": "2.21.0",
    "@ui5/webcomponents-react": "2.21.3",
    "axios": "^1.15.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-router": "7.14.0",
    "styled-components": "^6.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@ui5/webcomponents-cypress-commands": "2.21.3",
    "@vitejs/plugin-react": "6.0.1",
    "cypress": "15.13.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "prettier": "^3.8.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.5"
  }
}
